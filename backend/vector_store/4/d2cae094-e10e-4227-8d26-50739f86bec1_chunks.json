[{"text": "Basic VLSI System Design", "is_first": true, "is_last": false}, {"text": "Prof. A.Bakshi", "is_first": false, "is_last": false}, {"text": "School of Electronics Engineering", "is_first": false, "is_last": false}, {"text": "KIIT Deemed to be University", "is_first": false, "is_last": false}, {"text": "Mob. 8908448819", "is_first": false, "is_last": false}, {"text": "Introduction to VLSI Design", "is_first": false, "is_last": false}, {"text": "The electronics industry has achieved a phenomenal growth over the last two decades, mainly due to the rapid advances in", "is_first": false, "is_last": false}, {"text": "integration technologies, large-scale systems design - in short, due to the advent of VLSI.", "is_first": false, "is_last": false}, {"text": "Design Abstraction Levels", "is_first": false, "is_last": false}, {"text": "n+n+", "is_first": false, "is_last": false}, {"text": "S", "is_first": false, "is_last": false}, {"text": "G", "is_first": false, "is_last": false}, {"text": "D", "is_first": false, "is_last": false}, {"text": "+", "is_first": false, "is_last": false}, {"text": "DEVICE", "is_first": false, "is_last": false}, {"text": "CIRCUIT", "is_first": false, "is_last": false}, {"text": "GATE", "is_first": false, "is_last": false}, {"text": "MODULE", "is_first": false, "is_last": false}, {"text": "SYSTEM", "is_first": false, "is_last": false}, {"text": "Design Hierarchy", "is_first": false, "is_last": false}, {"text": "\u2022 The design hierarchy involves the principle of \"Divide and Conquer.\" It is nothing but dividing the", "is_first": false, "is_last": false}, {"text": "task into smaller tasks until it reaches to its simplest level. This process is most suitable because", "is_first": false, "is_last": false}, {"text": "the last evolution of design has become so simple that its manufacturing becomes easier..", "is_first": false, "is_last": false}, {"text": "Reference", "is_first": false, "is_last": false}, {"text": "\u2022 CMOS digital integrated circuits by Sung \u2013Mo KANG Y .Lebeleci4th", "is_first": false, "is_last": false}, {"text": "Edition,Mc-Graw Hill publications.", "is_first": false, "is_last": true}]